# Example environment file for CyberSentinel backend
# Copy this to `backend/.env` and fill in secrets. DO NOT commit your real `backend/.env` to git.

# Database
DATABASE_URL=sqlite:///./cybersentinel.db

# App security
SECRET_KEY=CHANGE_ME_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
DEBUG=True
LOG_LEVEL=INFO

# ML model
MODEL_PATH=./ml_models/threat_model.pkl
CONFIDENCE_THRESHOLD=0.75

# Default admin (used on first-run database seeding)
DEFAULT_ADMIN_NAME=CyberSentinel Admin
DEFAULT_ADMIN_EMAIL=your-admin@example.com
DEFAULT_ADMIN_PASSWORD=ChangeMe123!

# CORS / allowed origins (JSON array)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080","http://127.0.0.1:8000","http://localhost:8000"]

# SMTP Email Configuration (for sending alert emails)
# For Gmail: use your email and an app-specific password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-app-specific-password
SMTP_USE_TLS=True

# Twilio credentials
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+10000000000
USE_MOCK_TWILIO=False

# Default automated alert recipients
ALERT_SMS_RECIPIENTS=["+15551234567"]
ALERT_EMAIL_RECIPIENTS=["alerts@example.com"]

# NOTE: Keep backend/.env out of version control. Use a secrets manager for production.
DATABASE_URL=postgresql://postgres:YOURPASSWORD@localhost:5432/cybersentinel_db
SECRET_KEY=CHANGE_ME_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
DEBUG=True
LOG_LEVEL=INFO
MODEL_PATH=./ml_models/threat_model.pkl
CONFIDENCE_THRESHOLD=0.75
DEFAULT_ADMIN_NAME=CyberSentinel Admin
DEFAULT_ADMIN_EMAIL=mlestiwege@gmail.com
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080","http://127.0.0.1:8000","http://localhost:8000"]